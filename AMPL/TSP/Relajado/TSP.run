data instancia_TSP.dat;

solve;

# (1) Guardamos la solución en el archivo TSP_TS_out.txt
#########################################################

printf "# SOLUCION\n" > TSP_TS_out.txt;
for {k in 1..n,(i,j) in LINKS: r[k,i,j] > 0.5} {
    printf "%d %d\n", i, j >> TSP_TS_out.txt;
}
printf "# METRICAS\n" >> TSP_TS_out.txt;
printf "solve_time %f\n", _solve_elapsed_time >> TSP_TS_out.txt;
printf "obj %f\n", Total_Cost >> TSP_TS_out.txt;
printf "bestbound %f\n", Total_Cost.bestbound >> TSP_TS_out.txt;
